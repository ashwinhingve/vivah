ANTHROPIC_API_KEY=sk-ant-change-me
HELICONE_API_KEY=sk-helicone-change-me
MONGODB_URI=mongodb://smartshaadi:smartshaadi@localhost:27017/smartshaadiDB
REDIS_URL=redis://localhost:6379

# Internal auth — both names accepted by middleware + verify_internal_key dep.
# AI_SERVICE_API_KEY is the canonical name (matches apps/api/.env.example);
# INTERNAL_API_KEY kept for backwards compat with older deploys.
AI_SERVICE_API_KEY=internal-dev-key
INTERNAL_API_KEY=internal-dev-key

# Mock services (matches apps/api/.env.example) — when true, mock LLM/Helicone
# calls in feature routers (Phase 1+).
USE_MOCK_SERVICES=true

ENVIRONMENT=development
PORT=8000

# HuggingFace token (optional) — used by emotional-score router to load
# XLM-RoBERTa sentiment model with auth. Falls back to anonymous download
# when unset, but anonymous downloads hit rate limits in CI.
HF_TOKEN=

# Sentry error tracking (Phase 4 Day 2)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# Gates GET /sentry-test verification endpoint. Default false.
# SECURITY: NEVER set true in production except briefly during deploy verification —
# the endpoint deliberately raises an exception to validate Sentry capture.
SENTRY_TEST_ENABLED=false
