{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Explicit because pnpm's isolated node_modules layout defeats TypeScript's
    // automatic @types/* discovery: without this, every `describe`/`it`/`expect`
    // in a .ts test is an unresolved name and the suite contributes hundreds of
    // phantom type errors while running perfectly well under jest.
    "types": ["jest"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
