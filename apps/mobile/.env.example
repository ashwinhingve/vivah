# Base URL of the Smart Shaadi core API (Better Auth is mounted at /api/auth).
# EXPO_PUBLIC_* vars are inlined into the app bundle at build time.
#
# - iOS simulator / web:      http://localhost:4000
# - Android emulator:         http://10.0.2.2:4000   (emulator alias for host localhost)
# - Physical device on LAN:   http://<your-machine-LAN-IP>:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
