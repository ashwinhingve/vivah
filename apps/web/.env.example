NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_APP_NAME=Smart Shaadi
NEXT_PUBLIC_SITE_URL=https://smartshaadi.in

# Sentry — browser-side (NEXT_PUBLIC_*) for client errors,
# server-side (SENTRY_DSN) for Server Component + API route errors.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# Source-map upload (build-time, optional; skipped silently when unset)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
