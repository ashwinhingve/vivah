# ── Core ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database (Railway auto-injects DATABASE_URL) ──────────────
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://vivah:PASSWORD@cluster0.xxxxx.mongodb.net/smart_shaadi

# ── Redis (Railway auto-injects REDIS_URL) ────────────────────
REDIS_URL=redis://default:pass@host:6379

# ── Better Auth ───────────────────────────────────────────────
# Generate each with: openssl rand -base64 32
BETTER_AUTH_SECRET=GENERATE_WITH_openssl_rand_-base64_32
BETTER_AUTH_URL=https://api.smartshaadi.co.in

# ── JWT ───────────────────────────────────────────────────────
# JWT_SECRET is the source of truth (validated by env.ts, min 32 chars).
# ACCESS/REFRESH kept for forward-compat with Better Auth flows.
JWT_SECRET=GENERATE_WITH_openssl_rand_-base64_32
JWT_ACCESS_SECRET=GENERATE_WITH_openssl_rand_-base64_32
JWT_REFRESH_SECRET=GENERATE_WITH_openssl_rand_-base64_32

# ── URLs / CORS ───────────────────────────────────────────────
# WEB_URL is validated by env.ts. CORS_ORIGIN overrides the prod CORS
# allowlist in apps/api/src/index.ts.
WEB_URL=https://smartshaadi.co.in
API_BASE_URL=https://api.smartshaadi.co.in
CORS_ORIGIN=https://smartshaadi.co.in

# ── Cloudflare R2 ─────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY=your_access_key
CLOUDFLARE_R2_SECRET_KEY=your_secret_key
CLOUDFLARE_R2_BUCKET=smartshaadi-media
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Mock Services — production must be false (env.ts hard-rejects mock in prod) ──
# Set granular *_LIVE overrides (MONGO_LIVE, R2_LIVE) if you need to enable one
# real backend before all third-party registrations are complete.
USE_MOCK_SERVICES=false

# ── Third-party (mocked — swap after registration) ────────────
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder
RAZORPAY_WEBHOOK_SECRET=placeholder
MSG91_API_KEY=placeholder
MSG91_TEMPLATE_ID=placeholder
DIGILOCKER_CLIENT_ID=placeholder
DIGILOCKER_CLIENT_SECRET=placeholder
AWS_REKOGNITION_ACCESS_KEY=placeholder
AWS_REKOGNITION_SECRET_KEY=placeholder
AWS_REKOGNITION_REGION=ap-south-1
DAILY_CO_API_KEY=mock-daily-key

# ── AI Service (not deployed for demo) ────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_KEY=internal-service-key-dev

# ── Granular real-backend overrides ────────────────────────────
# When USE_MOCK_SERVICES=true is still acceptable for staging/demo, these flip
# specific backends to real without dropping the global mock flag.
MONGO_LIVE=true
R2_LIVE=true

# ── LLM (Anthropic + Helicone observability) ──────────────────
ANTHROPIC_API_KEY=
HELICONE_API_KEY=

# ── Email (AWS SES) ───────────────────────────────────────────
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=ap-south-1
AWS_SES_FROM=noreply@smartshaadi.co.in

# ── Push notifications (Firebase Cloud Messaging) ─────────────
# Paste the FULL service-account JSON as a single line (escape \n in private key).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Sentry — error + perf observability ───────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# Flip to true temporarily to verify Sentry is capturing, then back to false.
SENTRY_TEST_ENABLED=false

# ── Metrics endpoint bearer ────────────────────────────────────
# REQUIRED by env.ts superRefine when USE_MOCK_SERVICES=false — /metrics is
# otherwise world-readable. Generate with `openssl rand -hex 16`.
METRICS_TOKEN=

# ── Platform tax / GSTIN (over-ride placeholders before production launch) ──
PLATFORM_GSTIN=27AAAAA0000A1Z5
PLATFORM_STATE=Maharashtra

# ── E-invoicing (NIC IRP, triggers above ₹5,00,000 invoice value) ──
EINVOICE_API_KEY=
EINVOICE_THRESHOLD=500000

# ── Debug toggles ─────────────────────────────────────────────
# Verbose [feed] logging in matchmaking engine — leave off in prod.
FEED_DEBUG=false
