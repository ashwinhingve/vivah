# App
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# Mock services (set true until external registrations arrive)
USE_MOCK_SERVICES=true

# MongoDB connection mode — false = in-memory mockStore (apps/api/.data/mockStore.json),
# true = real MongoDB Atlas via MONGODB_URI. shouldUseMockMongo = USE_MOCK_SERVICES && !MONGO_LIVE.
MONGO_LIVE=false

# Razorpay payment integration — false = mock checkout/webhook, true = real Razorpay SDK.
# Flip to true ONLY after Razorpay company registration + KYC complete.
# When true, RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET / RAZORPAY_WEBHOOK_SECRET are required.
RAZORPAY_LIVE=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Verbose matchmaking diagnostic logs — only enable when debugging empty-feed bugs.
# Logs every step of the engine pipeline: candidate counts, filter decisions, score breakdown.
FEED_DEBUG=false

# Mock OTP override (only used when USE_MOCK_SERVICES=true).
# Local dev: leave commented, defaults to "123456".
# Staging/prod: uncomment and set to a random hard-to-guess value
# (e.g. `openssl rand -hex 4`). NOTE: an empty value (MOCK_OTP_VALUE=)
# bypasses the default and stores an empty OTP — DO NOT leave blank.
# MOCK_OTP_VALUE=

# Database
DATABASE_URL=postgresql://smartshaadi:smartshaadi@localhost:5432/smartshaadiDB
MONGODB_URI=mongodb://smartshaadi:smartshaadi@localhost:27017/smartshaadiDB
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=change-me-in-production-min-32-chars!!
JWT_SECRET=change-me-in-production-min-32-chars!!

# Storage (Cloudflare R2) — mocked when USE_MOCK_SERVICES=true
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET=smart-shaadi-dev
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com

# SMS (MSG91) — mocked when USE_MOCK_SERVICES=true
MSG91_API_KEY=mock-key
MSG91_TEMPLATE_ID=mock-template

# Email (AWS SES) — mocked when USE_MOCK_SERVICES=true
AWS_SES_ACCESS_KEY=mock-key
AWS_SES_SECRET_KEY=mock-secret
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@smartshaadi.co.in

# KYC (DigiLocker) — mocked when USE_MOCK_SERVICES=true
DIGILOCKER_CLIENT_ID=mock-client-id
DIGILOCKER_CLIENT_SECRET=mock-secret
DIGILOCKER_REDIRECT_URI=http://localhost:4000/api/v1/kyc/callback

# AWS Rekognition — mocked when USE_MOCK_SERVICES=true
AWS_REKOGNITION_REGION=ap-south-1
AWS_REKOGNITION_ACCESS_KEY=mock-key
AWS_REKOGNITION_SECRET_KEY=mock-secret

# Firebase — mocked when USE_MOCK_SERVICES=true
FIREBASE_SERVICE_ACCOUNT={}

# AI Service (internal)
AI_SERVICE_URL=http://localhost:8000
# Canonical name (matches ai-service .env.example):
AI_SERVICE_API_KEY=internal-dev-key
# Legacy alias — apps/api/src/lib/env.ts + ai/internal routes still read this name.
# Keep in sync with AI_SERVICE_API_KEY until the rename lands.
AI_SERVICE_INTERNAL_KEY=internal-dev-key

# LLM (Anthropic via Helicone) — only consumed by ai-service in prod;
# api may proxy via ai-service. Empty placeholders here for documentation.
ANTHROPIC_API_KEY=
HELICONE_API_KEY=

# Monitoring — Sentry error tracking (Phase 4 Day 2)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Trace sample rate (0.0–1.0). 0.1 = 10% of transactions traced in prod.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Gates GET /api/v1/sentry-test verification endpoint. Default false.
# SECURITY: NEVER set true in production except briefly during deploy verification —
# the endpoint deliberately throws an unhandled exception to validate Sentry capture.
SENTRY_TEST_ENABLED=false
