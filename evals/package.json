{
  "name": "@smartshaadi/evals",
  "version": "0.1.0",
  "private": true,
  "description": "AI regression eval harness (promptfoo) — golden sets for the 11 AI features, routed through Helicone.",
  "type": "module",
  "scripts": {
    "eval": "promptfoo eval -c promptfooconfig.yaml",
    "eval:ci": "promptfoo eval -c promptfooconfig.yaml --no-progress-bar --no-table --output results.json",
    "eval:ml": "promptfoo eval -c promptfooconfig.ml.yaml --no-progress-bar --no-table --output results-ml.json",
    "eval:llm": "promptfoo eval -c promptfooconfig.llm.yaml --no-progress-bar --no-table --output results-llm.json",
    "view": "promptfoo view"
  },
  "devDependencies": {
    "promptfoo": "0.121.19"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
