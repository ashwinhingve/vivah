# ═══════════════════════════════════════════════════════════
# Smart Shaadi — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

NODE_ENV=development

# ── Databases ──────────────────────────────────────────────
DATABASE_URL=postgresql://vivah:vivah@localhost:5432/smart_shaadi
MONGODB_URI=mongodb://vivah:vivah@localhost:27017/smart_shaadi
REDIS_URL=redis://localhost:6379

# ── Authentication ─────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars
BETTER_AUTH_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Cloudflare R2 (media storage) ──────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=smart-shaadi-dev
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Razorpay (payments) ────────────────────────────────────
# Use test keys during development
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# ── MSG91 (Indian OTP + SMS) ───────────────────────────────
MSG91_API_KEY=
MSG91_SENDER_ID=SHAADI
MSG91_OTP_TEMPLATE_ID=
MSG91_TRANSACTIONAL_TEMPLATE_ID=

# ── AWS SES (email) ────────────────────────────────────────
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@smartshaadi.co.in
AWS_SES_FROM_NAME=Smart Shaadi

# ── Firebase (push notifications) ──────────────────────────
# Paste the entire JSON as a single line or use base64
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── KYC & Identity ─────────────────────────────────────────
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=http://localhost:4000/api/v1/auth/kyc/callback

# AWS Rekognition (photo fraud detection)
AWS_REKOGNITION_ACCESS_KEY_ID=
AWS_REKOGNITION_SECRET_ACCESS_KEY=
AWS_REKOGNITION_REGION=ap-south-1

# ── Video Calls ────────────────────────────────────────────
DAILY_CO_API_KEY=

# ── AI / LLM ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
# Route all AI calls through Helicone for cost tracking
HELICONE_API_KEY=sk-helicone-xxx
# AI service is an internal service — shared secret for auth
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_KEY=internal-key-change-in-prod

# ── Monitoring ─────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://app.posthog.com
BETTERSTACK_SOURCE_TOKEN=

# ── App URLs ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.smartshaadi.co.in
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
