# Vercel sets NODE_ENV=production during build, which makes pnpm skip
# devDependencies. The Next.js build on Vercel needs tsc + turbo at
# install time, so force dev deps in regardless of NODE_ENV.
production=false

# apps/mobile (Expo/Metro): Metro's resolver does not follow pnpm's isolated
# .pnpm/ store cleanly for workspace packages. Hoisting only our own
# @smartshaadi/* packages into the root node_modules lets Metro resolve their
# built dist/ without symlink friction, while every external dep stays isolated.
public-hoist-pattern[]=@smartshaadi/*

# NativeWind compiles JSX to `react-native-css-interop/jsx-runtime` (via the
# babel jsxImportSource). That runtime is a transitive dep of nativewind, so
# Metro cannot resolve it from the app's node_modules under pnpm's isolated
# store — hoist the nativewind runtime packages so Metro finds them.
public-hoist-pattern[]=*react-native-css-interop*
public-hoist-pattern[]=nativewind
