{
  "name": "@smartshaadi/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/fix-esm-imports.mjs",
    "type-check": "node --max-old-space-size=6144 ../../node_modules/typescript/bin/tsc --noEmit",
    "type-check:seed": "node --max-old-space-size=12288 ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.seed.json",
    "test": "tsx seed/calendar.test.ts && tsx seed/demoTraffic.test.ts",
    "lint": "eslint schema",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx seed/index.ts",
    "db:seed:demo": "tsx seed/demoTraffic.ts",
    "db:seed:calendar": "tsx seed/calendar.ts",
    "db:seed:test-accounts": "tsx seed/test-accounts.ts",
    "db:seed:test-accounts:remove": "tsx seed/test-accounts.ts --remove",
    "db:seed:demo-01": "tsx seed/demo-01.ts",
    "db:seed:demo-01:remove": "tsx seed/demo-01.ts --remove",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.41.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.29.1",
    "mongoose": "^9.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
